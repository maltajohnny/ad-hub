# Usado automaticamente por `vite build`. Embute no bundle o redirect OAuth Google Ads (Worker).
# Deve coincidir com "URIs de redirecionamento autorizados" no Google Cloud (mesmo cliente OAuth que GOOGLE_ADS_CLIENT_ID).
VITE_INSIGHT_HUB_GOOGLE_ADS_REDIRECT_URI=https://google-ads-worker.ad-hub.workers.dev/google-ads/callback
