# Copie para `.env` na raiz do projeto e preencha. Não commite `.env` com segredos.
# Depois de alterar, reinicie `npm run dev`.

# IntelliSearch — local: `npm run intellisearch-api` ou `npm run dev:intellisearch`.
# Produção (Vercel): configure `SERPAPI_KEY` em Settings → Environment Variables (não precisa de `go run`).
# Opcional: URL absoluta se o API Go estiver noutro host.
# VITE_INTELLISEARCH_API_URL=https://api.seudominio.com
SERPAPI_KEY=

# Google Gemini — .../v1beta/models/${GEMINI_MODEL}:generateContent?key=...
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
