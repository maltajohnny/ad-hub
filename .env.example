# Copie para `.env` na raiz do projeto e preencha. Não commite `.env` com segredos.
# Depois de alterar, reinicie `npm run dev`.

# Slack: em produção (Vercel) o relay é `POST /api/slack-webhook` na mesma origem — não precisa definir.
# Só use se o relay estiver noutro domínio:
# VITE_SLACK_RELAY_URL=https://outro-backend.com

# Google Gemini — .../v1beta/models/${GEMINI_MODEL}:generateContent?key=...
GEMINI_API_KEY=
# Predefinição no código: gemini-2.5-flash — listar modelos: npm run gemini:list-models
# GEMINI_MODEL=gemini-2.5-pro
