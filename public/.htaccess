# AD-HUB — Vite SPA + rotas /api/intellisearch (proxy PHP em api/intellisearch/)
# Se já tiver um .htaccess no servidor, funda estas regras (sobretudo a exclusão de /api/intellisearch).
<IfModule mod_headers.c>
  Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
  Header always set Content-Security-Policy "default-src 'self'; base-uri 'self'; frame-ancestors 'none'; object-src 'none'; script-src 'self'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; img-src 'self' data: blob: https://ad-hub.digital https://quickchart.io; font-src 'self' data: https://fonts.gstatic.com; connect-src 'self' https://generativelanguage.googleapis.com https://serpapi.com https://graph.facebook.com https://business-api.tiktok.com https://hooks.slack.com; form-action 'self'; frame-src 'none'; upgrade-insecure-requests"
  Header always set X-Frame-Options "DENY"
  Header always set X-Content-Type-Options "nosniff"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
  Header always set Permissions-Policy "camera=(), microphone=(), geolocation=(), browsing-topics=(), interest-cohort=()"
  Header always set Cross-Origin-Opener-Policy "same-origin"
  Header always set Cross-Origin-Resource-Policy "same-site"
</IfModule>

<IfModule mod_rewrite.c>
RewriteEngine On
RewriteBase /

RewriteRule ^index\.html$ - [L]

# Não enviar pedidos IntelliSearch para o index.html da SPA
RewriteCond %{REQUEST_URI} ^/api/intellisearch/ [NC]
RewriteRule ^ - [L]

# Auth AD-Hub → proxy PHP (api/ad-hub/proxy.php)
RewriteCond %{REQUEST_URI} ^/api/ad-hub/ [NC]
RewriteRule ^ - [L]

# Scripts PHP em /api/social/ (ex.: HTML perfil Instagram para Social Pulse)
RewriteCond %{REQUEST_URI} ^/api/social/ [NC]
RewriteRule ^ - [L]

# Relay Slack (POST) — CORS-safe; ficheiro em api/slack-webhook.php
RewriteCond %{REQUEST_URI} ^/api/slack-webhook/?$ [NC]
RewriteRule ^api/slack-webhook/?$ api/slack-webhook.php [L,QSA]

RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

RewriteRule . /index.html [L]
</IfModule>
