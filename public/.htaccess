# AD-HUB — Vite SPA + rotas /api/intellisearch (proxy PHP em api/intellisearch/)
# Se já tiver um .htaccess no servidor, funda estas regras (sobretudo a exclusão de /api/intellisearch).
<IfModule mod_rewrite.c>
RewriteEngine On
RewriteBase /

RewriteRule ^index\.html$ - [L]

# Não enviar pedidos IntelliSearch para o index.html da SPA
RewriteCond %{REQUEST_URI} ^/api/intellisearch/ [NC]
RewriteRule ^ - [L]

# Auth AD-Hub → proxy PHP (api/ad-hub/proxy.php)
RewriteCond %{REQUEST_URI} ^/api/ad-hub/ [NC]
RewriteRule ^ - [L]

# Scripts PHP em /api/social/ (ex.: HTML perfil Instagram para Social Pulse)
RewriteCond %{REQUEST_URI} ^/api/social/ [NC]
RewriteRule ^ - [L]

# Relay Slack (POST) — CORS-safe; ficheiro em api/slack-webhook.php
RewriteCond %{REQUEST_URI} ^/api/slack-webhook/?$ [NC]
RewriteRule ^api/slack-webhook/?$ api/slack-webhook.php [L,QSA]

RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

RewriteRule . /index.html [L]
</IfModule>
